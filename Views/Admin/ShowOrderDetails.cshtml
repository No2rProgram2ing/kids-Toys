@using Kids_Toys.Models
@{
    Layout = "_LayoutAdmin";

    ViewData["Title"] = "Show All Order's Detail";
}
@model List<OrderDetail>


<div class="container mt-5">
    <div class="d-flex justify-content-between mb-4">
            <h2 >Orders' Detail List</h2>
    </div>
    <table class="table table-bordered table-striped text-center">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>OrderID</th>
                <th>ToyName</th>
                <th>Price</th>
                <th>Discount</th>
                <th>Quantity</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th style="width:20%;" >Manage Order's Detail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.OrderId</td>
                    <td>@item.ToyId</td>
                    <td>@item.Price</td>
                    <td>@item.Discount</td>
                    <td>@item.Quantity</td>
                    <td>@item.TotalPrice</td>
                    @if(@item.Status == 1)
                    {
                        <td>Confirmed Order</td>
                    }
                    else if(@item.Status == 2) 
                    {
                        <td>Shipping Order</td>
                    } else
                    { 
                        <td>Has Arrived</td>
                    }
                    <td>@item.CreatedAt</td>
                    <td>@item.UpdatedAt</td>
                    <td>
                        
                        <a class="btn btn-danger" role="button" onclick="togglePopupDel(@item.Id)"> Delete</a>
                        
                        @*Start Delete Cart*@
                        <div id="orderDetailDelete_@item.Id" class="popup">
                            <div>
                                <p style="padding:10px">Are you Sure that you want to delete @item.Id</p>
                                <input type="hidden" asp-for="@item.Id" id="ID_@item.Id" readonly>
                                <div>
                                    <input class="formBtn" onclick="DeleteOrderDetail(@item.Id)" type="submit" value="Submit" />
                                    <input class="formBtn" type="reset" value="Submit" />
                                </div>
                            </div>
                        </div>
                        @*End Delete Cart*@
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@section Scripts {
<script>


        // Start Delete Cart Detail

        function togglePopupDel(id) {
            const OrderDetailDelete = document.getElementById('orderDetailDelete_' + id);
            OrderDetailDelete.classList.toggle('show');
        }

        function DeleteOrderDetail(id) {

        const formData = new FormData
        formData.append("Id", id);

        fetch('/Admin/DeleteOrderDetail', {
            method: 'POST',
           body: formData
        })
        .then(response => {
            if (!response.ok) {
                // It is unsuccessful State
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            togglePopupDel(id); 
            location.reload();
            alert("It is successful");
        })
        .catch(err => {
            console.error('It is an error', err);
            alert('An error has happened');
        })
        }

        // End Delete Toy

</script>
}