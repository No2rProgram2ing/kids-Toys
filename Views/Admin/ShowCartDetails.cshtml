@using Kids_Toys.Models
@{
    Layout = "_LayoutAdmin";

    ViewData["Title"] = "Show All Cart's Detail";
}

@model List<CartDetail>

<div class="container mt-5">
    <div class="d-flex justify-content-between mb-4">
            <h2 >Carts' Detail List</h2>
    </div>
    <table class="table table-bordered table-striped text-center">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>CartID</th>
                <th>ToyName</th>
                <th>Price</th>
                <th>Discount</th>
                <th>Quantity</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th style="width:20%;" >Manage Cart's Detail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.CartId</td>
                    <td>@item.Toy.Name</td>
                    <td>@item.Price</td>
                    <td>@item.Discount</td>
                    <td>@item.Quentity</td>
                    <td>@item.CreatedAt</td>
                    <td>@item.UpdatedAt</td>
                    <td>
                        
                        <a class="btn btn-danger" role="button" onclick="togglePopupDel(@item.Id)"> Delete</a>
                        
                        @*Start Delete Cart Detail*@
                        <div id="cartDetailDelete_@item.Id" class="popup">
                            <div>
                                <p style="padding:10px">Are you Sure that you want to delete @item.Id</p>
                                <input type="hidden" asp-for="@item.Id" id="ID_@item.Id" readonly>
                                <div>
                                    <input class="formBtn" onclick="DeleteCartDetail(@item.Id)" type="submit" value="Submit" />
                                    <input class="formBtn" type="reset" value="Reset" />
                                </div>
                            </div>
                        </div>
                        @*End Delete Cart Detail*@
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

@section Scripts {
<script>


        // Start Delete Cart Detail

        function togglePopupDel(id) {
            const CartDetailDelete = document.getElementById('cartDetailDelete_' + id);
            CartDetailDelete.classList.toggle('show');
        }

        function DeleteCartDetail(id) {

        const formData = new FormData
        formData.append("Id", id);

        fetch('/Admin/DeleteCartDetail', {
            method: 'POST',
           body: formData
        })
        .then(response => {
            if (!response.ok) {
                // It is unsuccessful State
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            togglePopupDel(id); 
            location.reload();
            alert("It is successful");
        })
        .catch(err => {
            console.error('It is an error', err);
            alert('An error has happened');
        })
        }

        // End Delete Cart Detail

</script>
}