@using Kids_Toys.ModelViews
@{
    Layout = "_Layout";

    ViewData["Title"] = "Categories based on age";
}
@model CategoryToyMV
    <!-- Start breadcrumb -->
    <div class="info mt-3 mb-3 me-0">
        <div class="container  d-flex align-items-center justify-content-between">
            <div class="icon">
                <a href="../HTML/index.html">
                    <i class="fa-solid fa-circle-arrow-left fs-2"></i>
                </a>
            </div>
            <nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller= "Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller= "Home" asp-action="Category">Categories</a></li>
                    <li class="breadcrumb-item"><a asp-controller= "Home" asp-action="SubCategory" asp-route-name="@Model.SubCategoryName" >@Model.SubCategoryName</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.CategoryName</li>
                </ol>
            </nav>
        </div>
    </div>
    <!-- End breadcrumb -->

    <!-- Start navigation -->
     <div class="navigation-tabs mt-5 mx-auto">
      <div class="container">
        <ul class="nav nav-underline">
          <li class="nav-item mx-1 mx-md-3">
            <a href="" class="nav-link active" aria-current="page">All</a>
          </li>
          <li class="nav-item mx-1 mx-md-3">
            <a href="" class="nav-link" >Highest Sell</a>
          </li>
          <li class="nav-item mx-1 mx-md-3">
            <a href="" class="nav-link" >Highest Rated</a>
          </li>
          <li class="nav-item mx-1 mx-md-3">
            <a href="" class="nav-link" >Lowest Price</a>
          </li>
        </ul>
      </div>
     </div>
    <!-- End navigation -->



  <!-- Start Girls -->
  <div class="girls mt-5 py-5">
    <div class="container">
            <div class="row justify-content-between gap-4">
            @foreach(var toy in @Model.Toies)
            {
               <div class="col col-5 col-md-3 col-lg-2 mb-5 pb-3">
                <div class="box-toy position-relative">
                  <div class="image">
                    <img src="@toy.Image" alt="...">
                  </div>
                  <div class="box-toy-detail p-2">
                      <a asp-controller="Home" asp-action="ToyDetail" asp-route-id="@toy.Id"><p class="mb-0">@toy.Name</p></a>
                    <div class="icons d-flex justify-content-between mt-2">
                      <span class="fw-bold">@toy.Price $</span>
                      <span><i class="fa-regular fa-heart"></i></span>
                    </div>
                  </div>
                        <a class="position-absolute d-block button @(@toy.Status == true ? "" : "notAvailable")" onclick="@(@toy.Status == true ? "AddToCart(" + @toy.Id + ")" : "")" >Add to Cart</a>
                </div>
              </div>
            }
            </div>
    </div>
  </div>
  <!-- End Girls -->

 
